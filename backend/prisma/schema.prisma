generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["user", "game"]
}

model User {
  id           BigInt  @id @default(autoincrement())
  user_name    String  @unique @db.VarChar(50)
  password     String  @db.VarChar(36)
  email        String  @unique @db.VarChar(255)
  display_name String
  gender       Boolean
  avatar_seq   Int     @default(0)
  total_amount Int     @default(200)

  lucky_spins         Int       @default(0)
  lucky_claimed_at    DateTime? @db.Timestamptz(6)
  bonus_claimed_count Int       @default(0)
  bonus_claimed_at    DateTime? @db.Timestamptz(6)
  daily_claimed_count Int       @default(0)
  daily_claimed_at    DateTime? @db.Timestamptz(6)
  selected_tab        Int       @default(0)

  is_bot                Boolean                @default(false)
  room_users            RoomUser[]
  hosted_rooms          Room[]                 @relation("RoomHost")
  won_games             Game[]                 @relation("Game_winner")
  game_users            GameUser[]
  announcement_reads    UserAnnouncementRead[]
  user_amount_histories UserAmountHistory[]
  identities            UserIdentity[]
  user_achievements     UserAchievement[]

  @@map("users")
  @@schema("user")
}

model UserIdentity {
  id               BigInt   @id @default(autoincrement())
  user_id          BigInt
  provider         String   @db.VarChar(20)
  provider_user_id String   @db.VarChar(255)
  email            String?  @db.VarChar(255)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  users            User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, provider_user_id])
  @@index([user_id])
  @@map("user_identities")
  @@schema("user")
}

model UserAnnouncementRead {
  id                   BigInt   @id @default(autoincrement())
  user_id              BigInt
  session_id           String   @db.Uuid
  read_announcement_at DateTime @default(now()) @db.Timestamptz(6)
  users                User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, session_id])
  @@index([user_id, read_announcement_at(sort: Desc)])
  @@map("user_announcement_read")
  @@schema("game")
}

model Room {
  id         BigInt     @id @default(autoincrement())
  name       String
  status     Int        @db.SmallInt
  game_type  String     @default("chess") @db.VarChar(16)
  pve_mode   Boolean    @default(false)
  bet_amount Int        @default(10)
  time_limit     Int?
  time_increment Int    @default(0)
  time_per_move  Int    @default(0)
  host_id    BigInt?
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  updated_at DateTime   @default(now()) @db.Timestamptz(6)
  is_active  Boolean    @default(true)
  host       User?      @relation("RoomHost", fields: [host_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  room_users RoomUser[]
  games      Game[]

  @@map("rooms")
  @@schema("game")
}

model RoomUser {
  room_id   BigInt
  user_id   BigInt
  team      String?  @db.VarChar(10)
  joined_at DateTime @default(now()) @db.Timestamptz(6)
  rooms     Room     @relation(fields: [room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([room_id, user_id])
  @@map("room_users")
  @@schema("game")
}

model Game {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id        BigInt        @db.BigInt
  winner_id      BigInt?       @db.BigInt
  status         Int           @default(0) @db.SmallInt
  bot_difficulty Int?          @db.SmallInt
  game_type      String        @default("chess") @db.VarChar(16)
  time_limit     Int?
  time_increment Int           @default(0)
  time_per_move  Int           @default(0)
  room           Room          @relation(fields: [room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  winner         User?         @relation("Game_winner", fields: [winner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  starts_at      DateTime      @default(now()) @db.Timestamptz(6)
  ends_at        DateTime?
  game_users     GameUser[]

  @@map("games")
  @@schema("game")
}

model GameUser {
  game_id String  @db.Uuid
  user_id BigInt
  amount  Int?
  team    String? @db.VarChar(10)
  games   Game    @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users   User    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([game_id, user_id])
  @@map("game_users")
  @@schema("game")
}

model UserAmountHistory {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  amount     Int
  type       Int
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_amount_history")
  @@schema("game")
}

model Achievement {
  id                BigInt            @id @default(autoincrement())
  name              String
  user_achievements UserAchievement[]

  @@map("achievement")
  @@schema("game")
}

model UserAchievement {
  user_id        BigInt
  achievement_id BigInt
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  users          User        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  achievements   Achievement @relation(fields: [achievement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, achievement_id])
  @@index([achievement_id])
  @@map("user_achievements")
  @@schema("game")
}
